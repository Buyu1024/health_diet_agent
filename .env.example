# Qwen API Configuration (阿里云DashScope)
DASHSCOPE_API_KEY=你的密钥
QWEN_MODEL=qwen-plus

# MySQL Configuration (食谱营养数据)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=health_diet_db

# Milvus Configuration
MILVUS_URI=http://localhost:19530
MILVUS_DATABASE=health
MILVUS_COLLECTION=health_rag

# 本地模型路径（默认指向项目内 models/ 目录）
# BGE_M3_PATH=D:\PythonProject\health_diet_agent\models\bge-m3
# BGE_RERANKER_PATH=D:\PythonProject\health_diet_agent\models\bge-reranker-large

# A2A Protocol Configuration (双Agent通信)
A2A_AGENT_B_URL=http://127.0.0.1:8001/a2a/receive

# Database Connection String
DATABASE_URL=mysql+pymysql://root:@localhost:3306/health_diet_db

# MCP Server Configuration
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000

# Recipe Data CSV Path (本地数据源 / MySQL fallback)
# RECIPE_CSV_PATH=Tools/data/recipes_nutrition(样本).csv

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
